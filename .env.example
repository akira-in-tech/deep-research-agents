# Required external services
ANTHROPIC_API_KEY=
TAVILY_API_KEY=
VOYAGE_API_KEY=

# HTTP server
PORT=3000
APP_PORT=3000
NODE_ENV=development

# PostgreSQL (POSTGRES_DSN takes precedence when set)
POSTGRES_DSN=
POSTGRES_HOST=localhost
POSTGRES_PORT=5433
POSTGRES_USER=research
POSTGRES_PASSWORD=research
POSTGRES_DB=research_memory
TYPEORM_SYNC=true
TYPEORM_MIGRATIONS_RUN=false

# BullMQ and cross-instance progress events
REDIS_URL=redis://localhost:6379
QUEUE_ENABLED=true
QUEUE_CONCURRENCY=2
REDIS_EVENTS_ENABLED=true

# Milvus semantic memory
MILVUS_ADDRESS=localhost:19530
SEMANTIC_MEMORY_COLLECTION=semantic_memory

# Evaluation runner (optional number of dataset cases)
EVAL_LIMIT=5
